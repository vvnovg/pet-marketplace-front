# Local-dev template. `pnpm dev` reaches a backend running locally on :8080.
NEXT_PUBLIC_API_BASE=http://localhost:8080/api/v1

# Docker deployment does NOT need this file: docker-compose.yml's build-arg
# defaults NEXT_PUBLIC_API_BASE to http://host.docker.internal:8080/api/v1
# (the frontend container reaches the private backend via the host gateway).
# Set NEXT_PUBLIC_API_BASE in a deploy .env ONLY to override that default.
